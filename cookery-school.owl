<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://example.org/cookery#"
    xml:base="http://example.org/cookery"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <!-- =======================
         ONTOLOGY
    ======================== -->
    <owl:Ontology rdf:about="http://example.org/cookery"/>

    <!-- =======================
         CLASSES
    ======================== -->

    <owl:Class rdf:about="#Person"/>

    <owl:Class rdf:about="#Teacher">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <owl:disjointWith rdf:resource="#Student"/>
    </owl:Class>

    <owl:Class rdf:about="#Student">
        <rdfs:subClassOf rdf:resource="#Person"/>
    </owl:Class>

    <owl:Class rdf:about="#Class"/>
    <owl:Class rdf:about="#Technique"/>
    <owl:Class rdf:about="#Tool"/>
    <owl:Class rdf:about="#CuisineCulture"/>
    <owl:Class rdf:about="#Level"/>

    <!-- ✅ Recipe class with cardinality restriction (single definition) -->
    <owl:Class rdf:about="#Recipe">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#usesTechnique"/>
                <owl:minCardinality
                    rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">
                    1
                </owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- =======================
         OBJECT PROPERTIES
    ======================== -->

    <owl:ObjectProperty rdf:about="#teaches">
        <rdfs:domain rdf:resource="#Teacher"/>
        <rdfs:range rdf:resource="#Class"/>
        <owl:inverseOf rdf:resource="#isTaughtBy"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isTaughtBy">
        <rdfs:domain rdf:resource="#Class"/>
        <rdfs:range rdf:resource="#Teacher"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#attends">
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="#Class"/>
        <owl:inverseOf rdf:resource="#hasStudent"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasStudent">
        <rdfs:domain rdf:resource="#Class"/>
        <rdfs:range rdf:resource="#Student"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#includesRecipe">
        <rdfs:domain rdf:resource="#Class"/>
        <rdfs:range rdf:resource="#Recipe"/>
        <owl:inverseOf rdf:resource="#isIncludedIn"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isIncludedIn">
        <rdfs:domain rdf:resource="#Recipe"/>
        <rdfs:range rdf:resource="#Class"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#usesTechnique">
        <rdfs:domain rdf:resource="#Recipe"/>
        <rdfs:range rdf:resource="#Technique"/>
        <owl:inverseOf rdf:resource="#isTechniqueOf"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isTechniqueOf">
        <rdfs:domain rdf:resource="#Technique"/>
        <rdfs:range rdf:resource="#Recipe"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#requiresTool">
        <rdfs:domain rdf:resource="#Technique"/>
        <rdfs:range rdf:resource="#Tool"/>
        <owl:inverseOf rdf:resource="#isToolFor"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#isToolFor">
        <rdfs:domain rdf:resource="#Tool"/>
        <rdfs:range rdf:resource="#Technique"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#belongsToCulture">
        <rdfs:domain rdf:resource="#Recipe"/>
        <rdfs:range rdf:resource="#CuisineCulture"/>
        <owl:inverseOf rdf:resource="#hasRecipe"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasRecipe">
        <rdfs:domain rdf:resource="#CuisineCulture"/>
        <rdfs:range rdf:resource="#Recipe"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#containsTool">
        <rdfs:domain rdf:resource="#CuisineCulture"/>
        <rdfs:range rdf:resource="#Tool"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#hasLevel">
        <rdfs:domain rdf:resource="#Recipe"/>
        <rdfs:range rdf:resource="#Level"/>
        <owl:inverseOf rdf:resource="#levelOf"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="#levelOf">
        <rdfs:domain rdf:resource="#Level"/>
        <rdfs:range rdf:resource="#Recipe"/>
    </owl:ObjectProperty>

<!-- =======================
         DATA PROPERTIES (UPDATED)
    ======================== -->

    <owl:DatatypeProperty rdf:about="#personName">
        <rdfs:domain rdf:resource="#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#currentSkillLevel">
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#className">
        <rdfs:domain rdf:resource="#Class"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#recipeName">
        <rdfs:domain rdf:resource="#Recipe"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#cookingTime">
        <rdfs:domain rdf:resource="#Recipe"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#techniqueDescription">
        <rdfs:domain rdf:resource="#Technique"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="#toolPurpose">
        <rdfs:domain rdf:resource="#Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- =======================
         INDIVIDUALS (COUNTS EXACT)
         4 Teachers, 10 Students, 6 Classes, 6 Recipes,
         4 Techniques, 5 Tools, 3 Cultures, 3 Levels
    ======================== -->

    <!-- === LEVELS (3) === -->
    <owl:NamedIndividual rdf:about="#Beginner">
        <rdf:type rdf:resource="#Level"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Intermediate">
        <rdf:type rdf:resource="#Level"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Advanced">
        <rdf:type rdf:resource="#Level"/>
    </owl:NamedIndividual>

    <!-- === CUISINE CULTURES (3) === -->
    <owl:NamedIndividual rdf:about="#Italian">
        <rdf:type rdf:resource="#CuisineCulture"/>
        <containsTool rdf:resource="#tool_Pot"/>
        <containsTool rdf:resource="#tool_Whisk"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#French">
        <rdf:type rdf:resource="#CuisineCulture"/>
        <containsTool rdf:resource="#tool_Oven"/>
        <containsTool rdf:resource="#tool_Whisk"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Modern">
        <rdf:type rdf:resource="#CuisineCulture"/>
        <containsTool rdf:resource="#tool_Pan"/>
        <containsTool rdf:resource="#tool_Mixer"/>
    </owl:NamedIndividual>

    <!-- === TOOLS (5) === -->
    <owl:NamedIndividual rdf:about="#tool_Whisk">
        <rdf:type rdf:resource="#Tool"/>
        <toolPurpose>Used to whisk and combine ingredients smoothly</toolPurpose>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#tool_Pot">
        <rdf:type rdf:resource="#Tool"/>
        <toolPurpose>Used for boiling liquids and pasta</toolPurpose>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#tool_Oven">
        <rdf:type rdf:resource="#Tool"/>
        <toolPurpose>Used for baking and roasting using dry heat</toolPurpose>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#tool_Pan">
        <rdf:type rdf:resource="#Tool"/>
        <toolPurpose>Used for simmering and stove-top cooking</toolPurpose>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#tool_Mixer">
        <rdf:type rdf:resource="#Tool"/>
        <toolPurpose>Used for fast mixing and blending ingredients</toolPurpose>
    </owl:NamedIndividual>

    <!-- === TECHNIQUES (4) === -->
    <owl:NamedIndividual rdf:about="#technique_Mixing">
        <rdf:type rdf:resource="#Technique"/>
        <techniqueDescription>Combining ingredients until smooth and evenly mixed</techniqueDescription>
        <requiresTool rdf:resource="#tool_Whisk"/>
        <requiresTool rdf:resource="#tool_Mixer"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#technique_Boiling">
        <rdf:type rdf:resource="#Technique"/>
        <techniqueDescription>Cooking food in boiling water</techniqueDescription>
        <requiresTool rdf:resource="#tool_Pot"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#technique_Baking">
        <rdf:type rdf:resource="#Technique"/>
        <techniqueDescription>Cooking food using dry heat in an oven</techniqueDescription>
        <requiresTool rdf:resource="#tool_Oven"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#technique_Simmering">
        <rdf:type rdf:resource="#Technique"/>
        <techniqueDescription>Cooking gently in liquid just below boiling</techniqueDescription>
        <requiresTool rdf:resource="#tool_Pan"/>
    </owl:NamedIndividual>

    <!-- === RECIPES (6) === -->
    <owl:NamedIndividual rdf:about="#recipe_Tiramisu">
